# ====================================
# منصة محمد الربيعي التعليمية
# ملف المتغيرات البيئية
# ====================================

# ===== قاعدة البيانات =====
DATABASE_URL="postgresql://user:password@localhost:5432/mohamed_rabiei_lms?schema=public"

# ===== Next.js =====
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ===== JWT & Sessions =====
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
VIDEO_SIGNING_SECRET="your-video-signing-secret-key-change-in-production"

# ===== Redis (للجلسات) =====
REDIS_URL="redis://localhost:6379"

# ===== Bunny.net CDN (للفيديوهات) =====
BUNNY_STREAM_API_KEY="your-bunny-stream-api-key"
BUNNY_STREAM_LIBRARY_ID="your-library-id"

# ===== بوابات الدفع =====
# Fawry
FAWRY_MERCHANT_CODE="your-fawry-merchant-code"
FAWRY_SECRET_KEY="your-fawry-secret-key"
FAWRY_MODE="test" # test or production

# Paymob
PAYMOB_API_KEY="your-paymob-api-key"
PAYMOB_INTEGRATION_ID="your-integration-id"
PAYMOB_IFRAME_ID="your-iframe-id"

# ===== الإشعارات =====
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"

# ===== الأمان =====
RATE_LIMIT_MAX_REQUESTS="100"
RATE_LIMIT_WINDOW_MS="900000" # 15 دقيقة

# ===== تخزين الملفات =====
UPLOAD_MAX_SIZE="10485760" # 10MB
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/webp,application/pdf"
